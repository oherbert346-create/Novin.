GROQ_API_KEY=gsk_...
# Optional: for scripts/download_surveillance_datasets.py --roboflow
# ROBOFLOW_API_KEY=...
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
VISION_PROVIDER=groq
# REASONING: groq = fast (~4s total); cerebras = best quality
# Cerebras: gpt-oss-120b = ~6s (best quality); llama3.1-8b = ~2200 t/s (faster)
REASONING_PROVIDER=groq
# CEREBRAS_REASONING_MODEL=gpt-oss-120b
# CEREBRAS_REASONING_MODEL=llama3.1-8b
TOGETHER_API_KEY=...
TOGETHER_VISION_MODEL=Qwen/Qwen3-VL-8B-Instruct
TOGETHER_REASONING_MODEL=MiniMaxAI/MiniMax-M2.5
SILICONFLOW_API_KEY=...
SILICONFLOW_VISION_MODEL=Qwen/Qwen2.5-VL-7B-Instruct
SILICONFLOW_REASONING_MODEL=deepseek-ai/DeepSeek-V3.2
SILICONFLOW_REASONING_MAX_TOKENS=1000
SILICONFLOW_ENABLE_THINKING=true
SILICONFLOW_THINKING_BUDGET=1024
CEREBRAS_API_KEY=...
CEREBRAS_REASONING_MODEL=gpt-oss-120b
GROQ_REASONING_MODEL=qwen/qwen3-32b

# Database — PostgreSQL required for production (SQLite OK for local dev)
# Note: asyncpg handles SSL automatically for Neon, no sslmode param needed
DB_URL=postgresql+asyncpg://neondb_owner:password@ep-xxx.region.aws.neon.tech/neondb
# DB_URL=sqlite+aiosqlite:///./novin.db

# Auth — Basic HTTP Auth for all /api endpoints
BASIC_AUTH_USER=pilot_user
BASIC_AUTH_PASS=generate_secure_password_here

# Ingest API — required (non-negotiable). Clients must send x-api-key header.
INGEST_API_KEY=your-secret-ingest-key
# Or use LOCAL_API_CREDENTIAL for all /api paths
# LOCAL_API_CREDENTIAL=your-api-key
FRAME_JPEG_QUALITY=75
FRAME_MAX_WIDTH=1280
REASONING_TIMEOUT_MS=1200
REASONING_TEMPERATURE=0.0
REASONING_TOP_P=0.1
WEBHOOK_URL=
SLACK_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL_TO=
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
